@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<h2>Register</h2>

<form method="post">
    <div>
        <label>Name</label>
        <input asp-for="Input.Name" />
    </div>

    <div>
        <label>Email</label>
        <input asp-for="Input.Email" type="email" />
    </div>

    <div>
        <label>Password</label>
        <input asp-for="Input.Password" type="password" />
    </div>

    <button type="submit">Register</button>
</form>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <p>@Model.Message</p>
}

<script>
    // Слухаємо повідомлення від основного вікна
    window.addEventListener('message', (event) => {
        // Перевіряємо, чи повідомлення прийшло з правильного джерела
        if (event.origin !== window.location.origin) {
            console.error('Невідоме джерело повідомлення');
            return;
        }

        const { token } = event.data;
        if (!token) {
            alert('Токен не отримано');
            window.location.href = '/Error';
            return;
        }

        // Виконуємо запит на сервер для перевірки токена
        fetch('/api/auth/validate-token', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ token })
        }).then(response => {
            if (!response.ok) {
                alert('Недійсний токен');
                window.location.href = '/Error';
            } else {
                console.log('Токен успішно перевірено');
            }
        });
    });
</script>
